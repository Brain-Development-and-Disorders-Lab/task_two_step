{
  "name": "task_two_step",
  "version": "1.0.0",
  "description": "Two-Step behavior task adapted from the task described by Nussenbaum, K. (2020)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "clean": "rm -rf dist playwright-report test-results",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "yarn test:unit && yarn test:automated",
    "test:unit": "jest",
    "test:automated": "playwright test"
  },
  "dependencies": {
    "@jspsych/plugin-instructions": "^1.1.4",
    "@jspsych/plugin-survey-html-form": "^2.1.0",
    "jspsych": "^7.3.4",
    "neurocog": "^1.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7",
    "@typescript-eslint/parser": "^7",
    "css-loader": "^6.8.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "html-webpack-plugin": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.8.2",
    "style-loader": "^3.3.3",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "keywords": [
    "jspsych",
    "behavioral-task",
    "two-step",
    "typescript",
    "psychology"
